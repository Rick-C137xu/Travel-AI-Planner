# 前端运行模式。V3 仍默认使用前端 Mock，切到后端时改为 false。
VITE_USE_MOCK=true

# V3 后端地址。VITE_USE_MOCK=false 时必须填写，例如 http://127.0.0.1:8000 或 Render/Railway 地址。
VITE_API_BASE_URL=

# 高德地图配置。V3 仍默认留空，前端显示降级地点清单。
VITE_AMAP_KEY=
VITE_AMAP_SECURITY_CODE=

# 后端 CORS 配置。本地开发可保留 localhost，线上部署要加入 Vercel 前端地址。
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# V4 AI 服务配置。不填写 AI_API_KEY 时，后端会返回后端 Mock 数据。
# 不要把真实 Key 提交到仓库，只在本地 .env 或 Render 后台配置。
AI_PROVIDER=openai-compatible
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4.1-mini

# V4 高德 Web 服务 API Key。不配置时，后端不调高德，并在 envelope 中 amapEnabled=false。
AMAP_KEY=
AMAP_SECURITY_CODE=
