# 前端运行模式。V3 仍默认使用前端 Mock，切到后端时改为 false。
VITE_USE_MOCK=true

# V3 后端地址。VITE_USE_MOCK=false 时必须填写，例如 http://127.0.0.1:8000 或 Render/Railway 地址。
VITE_API_BASE_URL=

# 高德地图配置。V3 仍默认留空，前端显示降级地点清单。
VITE_AMAP_KEY=
VITE_AMAP_SECURITY_CODE=

# 后端 CORS 配置。本地开发可保留 localhost，线上部署要加入 Vercel 前端地址。
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# AI 服务配置。V3 不接真实 AI API，线上部署默认不需要填写。
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

# 后端预留高德地图配置。V3 不接真实地图 API，默认留空。
AMAP_KEY=
AMAP_SECURITY_CODE=
